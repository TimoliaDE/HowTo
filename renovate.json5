{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":separateMajorReleases",
    ":combinePatchMinorReleases"
  ],
  "minimumReleaseAge": "1 day",
  "labels": ["🤖 renovate"],
  "rebaseWhen": "conflicted",
  "assignees": ["feeeedox"],
  "reviewers": ["feeeedox"],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^Dockerfile$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)(?: versioning=(?<versioning>\\S+))?\\s+[^\\n]*?@(?<currentValue>[^\\s]+)"
      ]
    }
  ],
  "packageRules": [
    {
      "matchPackageNames": ["pnpm"],
      "groupName": "pnpm"
    }
  ]
}
