{
  "name": "timolia-howto",
  "version": "1.0.0",
  "description": "Documentation for Timolia, the Minecraft server network",
  "main": "index.js",
  "author": "Fedox",
  "license": "MIT",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "generate-team": "turbo run generate --filter=team-generator",
    "dev:docs": "turbo dev --filter=docs"
  },
  "private": true,
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.6.3"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  },
  "packageManager": "pnpm@11.1.3"
}
